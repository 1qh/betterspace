{
  "name": "betterspace",
  "version": "0.0.1",
  "description": "TypeScript CRUD library for SpacetimeDB. Maximum typesafety, thin consumer code.",
  "keywords": [
    "spacetimedb",
    "crud",
    "typesafety",
    "zod",
    "react",
    "nextjs",
    "fullstack",
    "forms",
    "file-upload",
    "pagination",
    "multi-tenancy",
    "acl",
    "soft-delete",
    "rate-limiting"
  ],
  "homepage": "https://github.com/1qh/betterspace",
  "bugs": "https://github.com/1qh/betterspace/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/1qh/betterspace.git",
    "directory": "packages/betterspace"
  },
  "license": "MIT",
  "author": "1qh",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./zod": "./src/zod.ts",
    "./retry": "./src/retry.ts",
    "./schema": "./src/schema.ts",
    "./react": "./src/react/index.ts",
    "./components": "./src/components/index.ts",
    "./eslint": "./src/eslint.ts",
    "./next": "./src/next/index.ts",
    "./test": "./src/server/test.ts",
    "./test/discover": "./src/server/test-discover.ts",
    "./seed": "./src/seed.ts"
  },
  "bin": {
    "betterspace": "./src/cli.ts"
  },
  "files": [
    "src",
    "!src/__tests__"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf dist node_modules",
    "format:md": "bunx prettier --single-quote --no-semi --trailing-comma none --print-width 80 --arrow-parens avoid --tab-width 2 --prose-wrap preserve --write '**/*.md' && flowmark --auto .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "browser-image-compression": "latest",
    "next-navigation-guard": "latest",
    "react-dropzone": "latest",
    "sharp": "latest"
  },
  "devDependencies": {
    "tsdown": "^0.20.3"
  },
  "peerDependencies": {
    "@auth/core": "^0.41",
    "@stepperize/react": "latest",
    "@tanstack/react-form": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "spacetimedb": "latest",
    "zod": "latest"
  }
}
